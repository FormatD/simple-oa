# Application
APP_NAME=Enterprise Management
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/enterprise_mgmt
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/enterprise_mgmt

# Redis Cache (RDB persistence)
REDIS_URL=redis://localhost:6379/0

# Redis Queue/Pub/Sub (AOF persistence, R3)
REDIS_QUEUE_URL=redis://localhost:6380/0

# JWT
JWT_SECRET_KEY=change-this-to-a-secure-random-secret-key
JWT_REFRESH_SECRET_KEY=change-this-to-another-secure-random-secret-key

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000

# TOTP
TOTP_ISSUER=Enterprise Management
TOTP_ENABLED=false

# RLS
ENABLE_RLS=true

# OpenTelemetry (R2)
OTEL_EXPORTER_ENDPOINT=

# Encryption (M4)
ENCRYPTION_KEY=
